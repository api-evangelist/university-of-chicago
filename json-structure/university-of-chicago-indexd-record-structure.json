{
  "$schema": "https://json-structure.org/meta/core/v0/#",
  "$id": "https://api-evangelist.com/university-of-chicago/json-structure/indexd-record-structure.json",
  "name": "Gen3 Indexd Record",
  "description": "JSON Structure for the Gen3 Indexd data object record (uc-cdis).",
  "type": "object",
  "properties": {
    "did": {
      "type": "string"
    },
    "baseid": {
      "type": "string"
    },
    "rev": {
      "type": "string"
    },
    "form": {
      "type": "string",
      "description": "how the entry was submitted to storage",
      "enum": [
        "object",
        "container",
        "multipart"
      ]
    },
    "size": {
      "type": "int64",
      "description": "size in bytes"
    },
    "file_name": {
      "type": "string"
    },
    "version": {
      "type": "string"
    },
    "uploader": {
      "type": "string"
    },
    "urls": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "acl": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "authz": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "hashes": {
      "type": "object"
    },
    "updated_date": {
      "type": "datetime",
      "description": "last updated time"
    },
    "created_date": {
      "type": "datetime",
      "description": "time created"
    },
    "metadata": {
      "type": "object"
    },
    "urls_metadata": {
      "type": "object"
    }
  },
  "required": []
}